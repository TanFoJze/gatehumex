<resources>

    <!-- Base application theme. -->
    <style name="AppTheme" parent="Theme.AppCompat.Light.NoActionBar">
        <!-- Customize your theme here. -->
        <item name="colorPrimary">@color/AppThemecolorPrimary</item>
        <item name="colorPrimaryDark">@color/AppThemecolorPrimary</item>
        <item name="colorAccent">@color/AppThemecolorAccent</item>
        
		<item name="colorBackgroundFloating">@android:color/transparent</item>
		
    </style>
	
		
		 <style name="thememain000" parent="Theme.AppCompat.Light.NoActionBar">
             
             <item name="colorBackgroundFloating">@android:color/transparent</item>
             
			 
			 <!-- 窗口背景透明 -->
			 <item name="android:windowBackground">@android:color/transparent</item>
			 
		<item name="colorBackgroundFloating">@android:color/transparent</item>
		

			 <!-- 窗口完全透明 -->
			 <item name="android:windowIsTranslucent">true</item>

			 <!-- 无窗口背景 -->
			 <item name="android:windowNoTitle">true</item>
			 
			 <!-- 状态栏透明 -->
			 <item name="android:statusBarColor">@android:color/transparent</item>

			 <!-- 导航栏透明 -->
			 <item name="android:navigationBarColor">@android:color/transparent</item>

			 <!-- 关键属性：让内容延伸到状态栏下 -->
			 <item name="android:windowTranslucentStatus">true</item>

			 <!-- 关键属性：让内容延伸到导航栏下 -->
			 <item name="android:windowTranslucentNavigation">true</item>

			 <!-- 另一个选择：使用全屏布局标志 -->
			 <item name="android:windowFullscreen">false</item> <!-- 不要设为true，否则会隐藏状态栏 -->

			 <!-- 对于 Android 5.0+ 更好的方式 -->
			 <item name="android:windowDrawsSystemBarBackgrounds">true</item>
			

			 <!-- 无过度动画 -->
			 <item name="android:windowAnimationStyle">@null</item>
			 
			 <item name="android:windowLayoutInDisplayCutoutMode">shortEdges</item>
             
             

			
		 </style>
         
         
         
    <style name="Desktop" parent="Theme.AppCompat.Light.NoActionBar">
        
        <item name="colorBackgroundFloating">@android:color/transparent</item>

        <!-- 1. 窗口背景透明，并显示系统壁纸  第二个是壁纸显示-->
        <item name="android:windowBackground">@android:color/transparent</item>
        <item name="android:windowShowWallpaper">true</item>

        <!-- 2. 沉浸式状态栏/导航栏（推荐做法） -->
        <item name="android:windowDrawsSystemBarBackgrounds">true</item>
        <item name="android:statusBarColor">@android:color/transparent</item>
        <item name="android:navigationBarColor">@android:color/transparent</item>
        
        <!-- 关键属性：让内容延伸到状态栏下 -->
        <item name="android:windowTranslucentStatus">true</item>

        <!-- 关键属性：让内容延伸到导航栏下 -->
        <item name="android:windowTranslucentNavigation">true</item>
        

        <!-- 3. 取消窗口动画（桌面启动器常用） -->
        <item name="android:windowAnimationStyle">@null</item>

        <!-- 4. 内容延伸到刘海/挖孔区域 -->
        <item name="android:windowLayoutInDisplayCutoutMode">shortEdges</item>

        <!-- 5. （可选）浮动窗口背景透明，非必须 -->
        <item name="colorBackgroundFloating">@android:color/transparent</item>

    </style>
    
    
    
    
    
    
         
    <style name="LockScreenTheme000" parent="Theme.AppCompat.Light.NoActionBar">

        <!-- 窗口背景透明 -->
        <item name="android:windowBackground">@android:color/transparent</item>

        <item name="colorBackgroundFloating">@android:color/transparent</item>


        <!-- 窗口完全透明 -->
        <item name="android:windowIsTranslucent">true</item>

        <!-- 无窗口背景 -->
        <item name="android:windowNoTitle">true</item>

        <!-- 状态栏透明 -->
        <item name="android:statusBarColor">@android:color/transparent</item>

        <!-- 导航栏透明 -->
        <item name="android:navigationBarColor">@android:color/transparent</item>

        <!-- 关键属性：让内容延伸到状态栏下 -->
        <item name="android:windowTranslucentStatus">true</item>

        <!-- 关键属性：让内容延伸到导航栏下 -->
        <item name="android:windowTranslucentNavigation">true</item>

        <!-- 另一个选择：使用全屏布局标志 -->
        <item name="android:windowFullscreen">true</item> <!-- 不要设为true，否则会隐藏状态栏 -->

        <!-- 对于 Android 5.0+ 更好的方式 -->
        <item name="android:windowDrawsSystemBarBackgrounds">true</item>


        <!-- 无过度动画 -->
        <item name="android:windowAnimationStyle">@null</item>

        <item name="android:windowLayoutInDisplayCutoutMode">shortEdges</item>
        
        <!-- 黑色状态栏图标 -->
        <item name="android:windowLightStatusBar">true</item>


    </style>
    

</resources>
